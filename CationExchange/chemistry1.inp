//********* Adsorption Model Exch *******************
//**** Model specific text **** 
@class: adsorptionmodeltext(Exch){

//The PHREEQC definition for comparison

EXCHANGE_MASTER_SPECIES
 Exch  Exch-


EXCHANGE_SPECIES
Exch- = Exch- ; log_k 0

EXCHANGE_SPECIES
Exch- + Na+ = ExchNa
     log_k  0

2 ExchNa + UO2+2 = Exch2UO2 + 2 Na+
     log_k  0.45
}
//**** End of model specific text **** 

//**** Model type code **** 
@class: adsorptionmodelcode(Basic_surface){
   @class: Basic_surface(name, parent_phase ,concentration){
      // The Basic surface model just contains of a single phase
      // that is linked to its parent phase via its concentration
      @phase(<name>, <parent_phase>, <concentration>)
   }
}
@adsorptionmodelcode(Basic_surface)
//**** End of model type code **** 

@adsmodel(Exch, ads ,1.1E-3, Basic_surface)
@surfsite(Exch, X, 1, 0)
@surfspecies(Exch, X, X-H, 1)
@logKreaction(Exch_X-H, 1.0, 1.0, Exch_X, 1.0, H+)
@surfspecies(Exch, X, X-K, 1)
@logKreaction(Exch_X-K, 0.7, 1.0, Exch_X, 1.0, K+)
@surfspecies(Exch, X, X-Na, 1)
@logKreaction(Exch_X-Na, 0.0, 1.0, Exch_X, 1.0, Na+)
@surfspecies(Exch, X, X2-Ca, 0.5)
@logKreaction(Exch_X2-Ca, 0.8, 1.0, Ca+2, 2.0, Exch_X)
//********* End of Adsorption Model Exch *************

//********* End of Adsorption Models *******
