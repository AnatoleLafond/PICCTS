@species(Cl-, -1)
@logKreaction(Cl-, 0.0, 1.0, Cl)
@species(K+, 1)
@logKreaction(K+, 0, 1.0, K)
@species(Na+, 1)
@logKreaction(Na+, 0.0, 1.0, Na)
@entity(e-, diss, 0)
@logKreaction(e-, 0, 1.0, E)
@entity(H[+0], tot, 0)
@logKreaction(H[+0], "(( (1.0 / log(10)) * ((-3.15 * log(10)) - (-7359.656 / 8.3144598) * ((1 / @T()) - (1 / 298.15))) ))", 2.0, H, 2.0, e-)
@species(H2, 0)
@logKreaction(H2, 0, 1.0, H[+0])
@species(NaOH, 0, 0.00, 0.00)
@logKreaction(NaOH, -14.18, -1.0, H+, 1.0, H2O, 1.0, Na+)
@entity(O[+0], tot, 0)
@logKreaction(O[+0], "((38.0229 + 0.00799407 * @T() + -27655.0 / @T() + -14.506 * log10(@T()) + 199838.45 / (@T() * @T())))", -4.0, H+, 2.0, O, -4.0, e-)
@species(O2, 0)
@logKreaction(O2, 0, 1.0, O[+0])
@species(OH-, -1)
@logKreaction(OH-, -13.9995, -1.0, H+, 1.0, H2O)

